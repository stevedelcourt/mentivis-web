# Mentivis — Apache config for Next.js static export
# Placed in public/ so it gets copied to out/ on build

# AVIF image format support
AddType image/avif .avif

# Disable directory listing
Options -Indexes

# Disable MultiViews — prevents Apache from serving fr.html instead of fr/index.html
Options -MultiViews

# Custom 404 page
ErrorDocument 404 /404/index.html

# Force index.html as directory index
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Canonical redirects: HTTP→HTTPS + non-WWW→WWW (mentivis.com only)
  RewriteCond %{HTTP_HOST} mentivis\.com$ [NC]
  RewriteCond %{HTTPS} off [OR]
  RewriteCond %{HTTP_HOST} !^www\. [NC]
  RewriteRule ^(.*)$ https://www.mentivis.com/$1 [R=301,L]

  # Root serves fr/index.html directly (no redirect needed)
  # RewriteRule ^$ /fr/ [R=301,L] — REMOVED, index.html is served by DirectoryIndex

  # Redirect old /expertises → /about (SEO)
  RewriteRule ^expertises$ /about/ [R=301,L]
  RewriteRule ^fr/expertises$ /fr/about/ [R=301,L]
  RewriteRule ^en/expertises$ /en/about/ [R=301,L]

  # Redirect old /resources → /guides (SEO)
  RewriteRule ^resources$ /guides/ [R=301,L]
  RewriteRule ^fr/resources$ /fr/guides/ [R=301,L]
  RewriteRule ^en/resources$ /en/guides/ [R=301,L]

  # Redirect /mentivissolutions → homepage (SEO consolidation)
  RewriteRule ^fr/mentivissolutions$ /fr/ [R=301,L]
  RewriteRule ^en/mentivissolutions$ /en/ [R=301,L]

  # Redirect /skillpath → /mentivisos (rebranding)
  RewriteRule ^fr/skillpath/?$ /fr/mentivisos/ [R=301,L]
  RewriteRule ^en/skillpath/?$ /en/mentivisos/ [R=301,L]

  # Redirect old insight slug → new slug (skillpath → mentivos rebranding)
  RewriteRule ^fr/insights/mentivis-devoile-skillpath-os-formation-native-ia/?$ /fr/insights/mentivis-devoile-mentivos-os-formation-native-ia/ [R=301,L]
  RewriteRule ^en/insights/mentivis-devoile-skillpath-os-formation-native-ia/?$ /en/insights/mentivis-devoile-mentivos-os-formation-native-ia/ [R=301,L]

  # Old WordPress URLs → new Next.js routes (SEO preservation)
  RewriteRule ^creation-decole-et-centre-de-formation-en-france/?$ /fr/of/ [R=301,L]
  RewriteRule ^offres-mentivis-conseil-et-transformation-educative/?$ /fr/of/ [R=301,L]
  RewriteRule ^jobs-et-offres-demploi/?$ /fr/careers/ [R=301,L]
  RewriteRule ^carrieres/?$ /fr/careers/ [R=301,L]
  RewriteRule ^contact-general/?$ /fr/contact/ [R=301,L]
  RewriteRule ^les-guides-de-reference-mentivis/?$ /fr/guides/ [R=301,L]
  RewriteRule ^mentivis-solutions-conseil-ingenierie-transformation-digitale/?$ /fr/solutions/ [R=301,L]
  RewriteRule ^blog/insights/?$ /fr/insights/ [R=301,L]

  # If request is a directory, serve its index.html
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^(.*)$ $1/index.html [L]
</IfModule>

# Never cache any HTML files — fixes o2switch CDN stale cache
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "max-age=0, no-cache, no-store, must-revalidate"
    Header set Pragma "no-cache"
    Header set Expires "0"
  </FilesMatch>

  # Aggressive cache for static assets
  <FilesMatch "\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|webp|avif)$">
    Header set Cache-Control "max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Compress text assets
<IfModule mod_deflate.c>
    SetOutputFilter DEFLATE
    # On compresse tout sauf les images (déjà compressées)
    AddOutputFilterByType DEFLATE text/plain
    AddOutputFilterByType DEFLATE text/html
    AddOutputFilterByType DEFLATE text/xml
    AddOutputFilterByType DEFLATE text/css
    AddOutputFilterByType DEFLATE application/xml
    AddOutputFilterByType DEFLATE application/xhtml+xml
    AddOutputFilterByType DEFLATE application/rss+xml
    AddOutputFilterByType DEFLATE application/javascript
    AddOutputFilterByType DEFLATE application/x-javascript
    AddOutputFilterByType DEFLATE application/json
</IfModule>
